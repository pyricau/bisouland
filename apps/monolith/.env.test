# Database
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_USER=skyswoon
DATABASE_PASSWORD=skyswoon_pass
DATABASE_NAME=skyswoon_test
# MySQL root password (for Docker)
MYSQL_ROOT_PASSWORD=root_password

# Performance Monitoring (disabled by default)
# Set to true to record server-side execution times to the database
PERFORMANCE_RECORDING_ENABLED=false
